{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "encode",
  "version": "0.4.0",
  "identifier": "com.encode.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Encode",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlEQ0FBMzUxNEQ0M0RGRDcKUldUWDMwTk5VYVBLbmJBNXJCR0RvT1dWNTVaRkFEdEdFQTdEN2FxS3ZvNEoxNk4vVllwTE44Z1oK",
      "endpoints": [
        "https://github.com/samieh-abdeljabbar/encode-app/releases/latest/download/latest.json"
      ]
    }
  }
}
