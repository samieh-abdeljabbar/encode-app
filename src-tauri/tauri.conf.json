{
  "productName": "Encode",
  "version": "2.0.0-alpha.6",
  "identifier": "com.encode.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost http://localhost:*"
    },
    "windows": [
      {
        "title": "Encode",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1MTk3MTg3REMzNzVGNjgKUldSb1h6ZmNoM0VacFhGQ3poT1NFdlFtOUw1eC9MWVczNnoxZ3RRa29MMy9ha2p1S2lTZXdRbzUK",
      "endpoints": [
        "https://github.com/samieh-abdeljabbar/encode-app/releases/latest/download/latest.json"
      ]
    }
  }
}
